# Agentic Quest — Environment Configuration
# Copy this file to .env: cp .env.example .env

# Agent harness: "claude" (recommended) or "codex"
# Claude Code provides the best experience — richer narration, better tool use, subagent support
AQ_AGENT=claude

# Eco mode: uses your agent CLI for world generation (no API key needed)
# Set to "on" for zero-cost generation, or "off" to use the Anthropic API directly
ECO=on

# Anthropic API key (only needed if ECO=off)
# Get one at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
